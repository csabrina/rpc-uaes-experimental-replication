{
  "http://localhost:7002": [
    {
      "selector": "[data-cy=\"todo-filter-all\"]",
      "tag": "<a data-cy=\"todo-filter-all\" class=\"selected\" href=\"#/\">All</a>"
    },
    {
      "selector": "[data-cy=\"todo-filter-active\"]",
      "tag": "<a data-cy=\"todo-filter-active\" class=\"\" href=\"#/active\">Active</a>"
    },
    {
      "selector": "[data-cy=\"todo-filter-completed\"]",
      "tag": "<a data-cy=\"todo-filter-completed\" class=\"\" href=\"#/completed\">Completed</a>"
    },
    {
      "selector": "[data-cy=\"todo-clear-completed\"]",
      "tag": "<button class=\"clear-completed\" data-cy=\"todo-clear-completed\" hidden=\"\">Clear completed</button>"
    },
    {
      "selector": "[data-cy=\"todo-info-site\"]",
      "tag": "<a href=\"http://todomvc.com\" data-cy=\"todo-info-site\">TodoMVC</a>"
    },
    {
      "selector": "[data-cy=\"todo-new\"]",
      "tag": "<input class=\"new-todo\" data-cy=\"todo-new\" data-testid=\"text-input\" aria-label=\"New Todo Input\" placeholder=\"What needs to be done?\" type=\"text\">"
    },
    {
      "selector": "[data-cy=\"todo-toggle-all\"]",
      "tag": "<input class=\"toggle-all\" id=\"toggle-all\" data-cy=\"todo-toggle-all\" data-testid=\"toggle-all\" type=\"checkbox\">"
    }
  ]
}